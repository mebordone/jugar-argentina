---
import { listaHrefByStatKey } from "../lib/listas";
import { sitePath } from "../lib/links";

type Props = {
  stats: {
    total: number;
    candidatos: number;
    descartados: number;
    vinculos: {
      escenario: number;
      protagonista: number;
      deporte: number;
    };
  };
};

const { stats } = Astro.props;

const items = [
  { key: "total" as const, count: stats.total, label: "juegos verificados" },
  { key: "candidatos" as const, count: stats.candidatos, label: "candidatos rastreados" },
  {
    key: "escenario" as const,
    count: stats.vinculos.escenario,
    label: "con escenario argentino",
  },
  {
    key: "protagonista" as const,
    count: stats.vinculos.protagonista,
    label: "con protagonistas argentinos",
  },
  { key: "descartados" as const, count: stats.descartados, label: "descartes explicados" },
];
---

<section class="stats-strip" aria-label="Estadísticas de la base">
  {
    items.map((item) => (
      <a class="stats-strip-link" href={sitePath(listaHrefByStatKey[item.key])}>
        <strong>{item.count}</strong>
        <span>{item.label}</span>
      </a>
    ))
  }
</section>
