---
import Badge from "./Badge.astro";
import GameAccess from "./GameAccess.astro";
import GameCover from "./GameCover.astro";
import { humanize, tipoObraTone } from "../lib/filters";
import { sitePath } from "../lib/links";
import { reportGameUrl } from "../lib/report";
import type { GameView } from "../lib/games";

type Props = {
  game: GameView;
  fromRecorrido?: string;
};

const { game, fromRecorrido } = Astro.props;
const fichaHref = fromRecorrido
  ? sitePath(`/juegos/${game.id}?from=${fromRecorrido}`)
  : sitePath(`/juegos/${game.id}`);
const place =
  game.contexto_argentino.provincias[0] || game.contexto_argentino.regiones[0];
---

<article class="game-card">
  <GameCover game={game} />
  <div class="game-card-content">
    <p class="eyebrow">
      {game.anio ?? "Sin fecha"} · {game.plataformas.slice(0, 3).join(", ")}
    </p>
    <h3><a href={fichaHref}>{game.titulo}</a></h3>
    <p>{game.culturalSummary || game.descripcion}</p>
    <div class="badge-row">
      <Badge label={humanize(game.tipo_obra)} tone={tipoObraTone(game.tipo_obra)} />
      {game.badges.slice(1, 5).map((badge) => <Badge label={badge} />)}
      {place && <Badge label={place} tone="cool" />}
      <Badge label={humanize(game.grado_relevancia_argentina)} tone="warm" />
      {!game.isPlayableToday && <Badge label="Sin link de juego" tone="muted" />}
    </div>
  </div>
  <div class="game-card-actions">
    <GameAccess
      actions={game.actions}
      primary={game.primaryAction}
      compact
      disponibilidad={game.disponibilidad}
      isPlayable={game.isPlayableToday}
    />
    <a class="button button-secondary" href={fichaHref}>
      Ver ficha
    </a>
    <a
      class="game-card-report"
      href={reportGameUrl(game)}
      target="_blank"
      rel="noreferrer"
    >
      Sugerir corrección
    </a>
  </div>
</article>
