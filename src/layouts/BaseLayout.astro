---
import "../styles/global.css";
import { SITE } from "../site.config";
import { absoluteUrl, sitePath } from "../lib/links";

type Props = {
  title?: string;
  description?: string;
};

const { title = SITE.name, description = SITE.description } = Astro.props;
const pageTitle = title === SITE.name ? title : `${title} · ${SITE.name}`;
const canonicalUrl = absoluteUrl(Astro.url.pathname);
const ogImage = absoluteUrl("/og-default.png");
const favicon = sitePath("/favicon.svg");
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href={favicon} type="image/svg+xml" />
    <title>{pageTitle}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,700;0,9..40,900;1,9..40,400&family=DM+Serif+Display:ital@0;1&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="site-header">
      <a href={sitePath("/")} class="brand" aria-label="Inicio">
        <span class="brand-mark">JA</span>
        <span>
          <strong>{SITE.name}</strong>
          <small>{SITE.tagline}</small>
        </span>
      </a>
      <nav class="nav">
        <a href={sitePath("/catalogo")}>Catálogo</a>
        <a href={sitePath("/recorridos/independencia")}>Recorridos</a>
        <a href={sitePath("/curaduria")}>Curaduría</a>
        <a href={sitePath("/sugerir")}>Sugerí un juego</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>
        <strong>{SITE.name}</strong> es una base curada para descubrir, jugar y
        compartir videojuegos vinculados a la cultura argentina.
      </p>
      <p>Datos abiertos desde JSON estático. Hecho para publicarse en GitHub Pages.</p>
    </footer>
  </body>
</html>
