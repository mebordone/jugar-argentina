---
import "../styles/global.css";
import { SITE } from "../site.config";
import { absoluteUrl, sitePath } from "../lib/links";

type Props = {
  title?: string;
  description?: string;
  ogImage?: string;
  currentPath?: string;
};

const {
  title = SITE.name,
  description = SITE.description,
  ogImage = absoluteUrl("/og-default.png"),
  currentPath = Astro.url.pathname,
} = Astro.props;
const pageTitle = title === SITE.name ? title : `${title} · ${SITE.name}`;
const canonicalUrl = absoluteUrl(Astro.url.pathname);
const favicon = sitePath("/favicon.svg");

function isActive(href: string) {
  const normalized = href.replace(/\/$/, "") || "/";
  const current = currentPath.replace(/\/$/, "") || "/";
  if (normalized === sitePath("/").replace(/\/$/, "") || normalized === "/") {
    return current === sitePath("/").replace(/\/$/, "") || current === "/";
  }
  return current.startsWith(normalized);
}

const navItems = [
  { href: "/catalogo", label: "Catálogo" },
  { href: "/recorridos", label: "Recorridos" },
  { href: "/listas/juegos-verificados", label: "Listas" },
  { href: "/curaduria", label: "Curaduría" },
  { href: "/sugerir", label: "Sugerí un juego" },
];
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:locale" content="es_AR" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href={favicon} type="image/svg+xml" />
    <title>{pageTitle}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,700;0,9..40,900;1,9..40,400&family=DM+Serif+Display:ital@0;1&display=swap"
      rel="stylesheet"
    />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      name: SITE.name,
      description: SITE.description,
      url: SITE.siteUrl,
    })} />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Ir al contenido</a>
    <header class="site-header">
      <a href={sitePath("/")} class="brand" aria-label="Inicio">
        <span class="brand-mark">JA</span>
        <span>
          <strong>{SITE.name}</strong>
          <small>{SITE.tagline}</small>
        </span>
      </a>
      <nav class="nav" aria-label="Principal">
        {
          navItems.map((item) => (
            <a
              href={sitePath(item.href)}
              aria-current={isActive(item.href) ? "page" : undefined}
            >
              {item.label}
            </a>
          ))
        }
      </nav>
    </header>
    <main id="main-content">
      <slot />
    </main>
    <footer class="site-footer">
      <p>
        <strong>{SITE.name}</strong> es una base curada para descubrir, jugar y
        compartir videojuegos vinculados a la cultura argentina.
      </p>
      <nav class="footer-nav" aria-label="Mapa del sitio">
        <a href={sitePath("/catalogo")}>Catálogo</a>
        <a href={sitePath("/recorridos")}>Recorridos</a>
        <a href={sitePath("/listas/juegos-verificados")}>Listas</a>
        <a href={sitePath("/curaduria")}>Curaduría</a>
        <a href={sitePath("/sugerir")}>Sugerí un juego</a>
        <a href={sitePath("/data/games.json")} download>Descargar datos (JSON)</a>
      </nav>
      <p>Datos abiertos desde JSON estático. Hecho para publicarse en GitHub Pages.</p>
    </footer>
  </body>
</html>
