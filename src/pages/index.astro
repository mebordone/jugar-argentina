---
import BaseLayout from "../layouts/BaseLayout.astro";
import GameCard from "../components/GameCard.astro";
import StatsStrip from "../components/StatsStrip.astro";
import { QUICK_FILTERS } from "../lib/filters";
import { sitePath } from "../lib/links";
import { games, getStats } from "../lib/games";
import { getTodayRecorrido, getRecomendadosRecorrido, gamesForRecorrido } from "../lib/recorridos";

const stats = getStats();
const today = getTodayRecorrido();
const recomendados = getRecomendadosRecorrido();
const allTodayGames = gamesForRecorrido(today);
const todayGames = allTodayGames.slice(0, 4);
const todayTotal = allTodayGames.length;
const todayIds = new Set(allTodayGames.map((game) => game.id));
const allRecomendados = gamesForRecorrido(recomendados);
const recomendadosTotal = allRecomendados.length;
const featured = allRecomendados
  .filter((game) => !todayIds.has(game.id))
  .slice(0, 6);
---

<BaseLayout>
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">Catálogo cultural jugable</p>
      <h1>¿Qué querés jugar de Argentina hoy?</h1>
      <p>
        Descubrí videojuegos para recorrer historia, folclore, política,
        territorios, deportes y cultura popular argentina.
      </p>
      <form class="hero-search" action={sitePath("/catalogo")}>
        <input
          name="q"
          type="search"
          placeholder="Buscá Malvinas, truco, Mendoza, San Martín..."
          aria-label="Buscar juegos"
        />
        <button class="button button-primary" type="submit">Buscar</button>
      </form>
      <div class="chip-row">
        {QUICK_FILTERS.map((filter) => (
          <a href={sitePath(filter.href)} class="chip">{filter.label}</a>
        ))}
      </div>
    </div>
    <aside class="hero-card">
      <p class="eyebrow">Hoy en Jugar Argentina</p>
      <h2>{today.titulo}</h2>
      <p>{today.descripcion}</p>
      <a class="button button-secondary" href={sitePath(`/recorridos/${today.slug}`)}>
        Ver recorrido
      </a>
    </aside>
  </section>

  <StatsStrip stats={stats} />

  <section class="section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Efemérides y recorridos</p>
        <h2>{today.titulo}</h2>
        {todayTotal > 4 && (
          <p class="section-subtitle">
            4 destacados de un recorrido de {todayTotal} juegos
          </p>
        )}
      </div>
      <a href={sitePath(`/recorridos/${today.slug}`)}>
        Ver los {todayTotal} juegos
      </a>
    </div>
    <div class="game-grid">
      {todayGames.map((game) => <GameCard game={game} />)}
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Para empezar a jugar</p>
        <h2>Recomendados del catálogo</h2>
        <p class="section-subtitle">
          {featured.length} destacados de un recorrido de {recomendadosTotal} juegos
        </p>
      </div>
      <a href={sitePath("/recorridos/recomendados")}>
        Ver los {recomendadosTotal} juegos
      </a>
    </div>
    <div class="game-grid">
      {featured.map((game) => <GameCard game={game} />)}
    </div>
  </section>
</BaseLayout>
