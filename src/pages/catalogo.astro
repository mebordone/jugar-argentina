---
import BaseLayout from "../layouts/BaseLayout.astro";
import GameCard from "../components/GameCard.astro";
import GameFilters from "../components/GameFilters";
import { filterGames, parseCatalogFilters } from "../lib/filterGames";
import { games, getFilterOptions } from "../lib/games";

const options = getFilterOptions();
const basePath = import.meta.env.BASE_URL || "/";
const initialFilters = parseCatalogFilters(Astro.url.searchParams);
const initialGames = filterGames(games, initialFilters);
const ssrPreview = initialGames.slice(0, 24);
---

<BaseLayout
  title="Catálogo"
  description="Catálogo filtrable de videojuegos vinculados a Argentina."
>
  <section class="page-hero">
    <p class="eyebrow">Catálogo</p>
    <h1>Encontrá juegos por tema, provincia, plataforma o disponibilidad</h1>
    <p>
      Usá los filtros y compartí la URL: cada búsqueda queda guardada en el enlace.
    </p>
  </section>

  <noscript>
    <div class="catalog-panel">
      <div class="result-heading">
        <p>
          <strong>{initialGames.length}</strong> juegos encontrados
        </p>
      </div>
      <div class="game-grid">
        {ssrPreview.map((game) => <GameCard game={game} />)}
      </div>
    </div>
  </noscript>

  <GameFilters
    games={games}
    options={options}
    basePath={basePath}
    initialFilters={initialFilters}
    client:load
  />
</BaseLayout>
