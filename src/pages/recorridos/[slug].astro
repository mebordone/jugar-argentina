---
import BaseLayout from "../../layouts/BaseLayout.astro";
import GameCard from "../../components/GameCard.astro";
import ShareBlock from "../../components/ShareBlock.astro";
import {
  destacadosForRecorrido,
  formatRecorridoFecha,
  gamesForRecorrido,
  relatedForRecorrido,
  recorridos,
} from "../../lib/recorridos";
import { sitePath } from "../../lib/links";

export function getStaticPaths() {
  return recorridos.map((recorrido) => ({
    params: { slug: recorrido.slug },
    props: { recorrido },
  }));
}

const { recorrido } = Astro.props;
const destacados = destacadosForRecorrido(recorrido);
const relacionados = relatedForRecorrido(recorrido);
const recorridoGames = gamesForRecorrido(recorrido);
const fechaLabel = formatRecorridoFecha(recorrido.fecha);
---

<BaseLayout title={recorrido.titulo} description={recorrido.descripcion}>
  <section class="page-hero">
    <a class="back-link" href={sitePath("/recorridos")}>Todos los recorridos</a>
    <p class="eyebrow">
      Recorrido cultural{fechaLabel ? ` · ${fechaLabel}` : ""}
    </p>
    <h1>{recorrido.titulo}</h1>
    <p>{recorrido.descripcion}</p>
    <div class="chip-row">
      {recorrido.temas.map((tema) => (
        <a class="chip" href={sitePath(`/catalogo?tema=${encodeURIComponent(tema)}`)}>
          {tema.replaceAll("_", " ")}
        </a>
      ))}
    </div>
  </section>

  <ShareBlock
    title={recorrido.titulo}
    text={`Un recorrido de Jugar Argentina para explorar: ${recorrido.temas.join(", ")}.`}
  />

  <section class="section recorrido-section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Curados para este recorrido</p>
        <h2>Destacados del recorrido</h2>
        <p class="section-subtitle">
          {destacados.length} juego{destacados.length === 1 ? "" : "s"} elegidos a mano
        </p>
      </div>
    </div>
    <div class="game-grid">
      {destacados.map((game) => <GameCard game={game} />)}
    </div>
  </section>

  {relacionados.length > 0 && (
    <section class="section recorrido-section">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Del catálogo</p>
          <h2>Más juegos relacionados</h2>
          <p class="section-subtitle">
            {relacionados.length} sugerencia{relacionados.length === 1 ? "" : "s"} automáticas por tema. En total, {recorridoGames.length} juegos en este recorrido.
          </p>
        </div>
      </div>
      <div class="game-grid">
        {relacionados.map((game) => <GameCard game={game} />)}
      </div>
    </section>
  )}
</BaseLayout>
