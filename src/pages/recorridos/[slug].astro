---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import GameCard from "../../components/GameCard.astro";
import ShareBlock from "../../components/ShareBlock.astro";
import { catalogQueryForTemas } from "../../lib/filterGames";
import {
  destacadosForRecorrido,
  formatRecorridoTipo,
  motivoForDestacado,
  recorridoFechaLabel,
  recorridos,
} from "../../lib/recorridos";
import { humanize } from "../../lib/filters";
import { sitePath } from "../../lib/links";

export function getStaticPaths() {
  return recorridos.map((recorrido) => ({
    params: { slug: recorrido.slug },
    props: { recorrido },
  }));
}

const { recorrido } = Astro.props;
const destacados = destacadosForRecorrido(recorrido);
const fechaLabel = recorridoFechaLabel(recorrido);
const catalogHref = sitePath(catalogQueryForTemas(recorrido.temas));
const tipoLabel = formatRecorridoTipo(recorrido.tipo);
---

<BaseLayout title={recorrido.titulo} description={recorrido.descripcion}>
  <Breadcrumbs
    items={[
      { label: "Recorridos", href: "/recorridos" },
      { label: recorrido.titulo },
    ]}
  />
  <section class="page-hero">
    <a class="back-link" href={sitePath("/recorridos")}>Todos los recorridos</a>
    <p class="eyebrow">
      {tipoLabel}{fechaLabel ? ` · ${fechaLabel}` : ""}
    </p>
    <h1>{recorrido.titulo}</h1>
    <p>{recorrido.bajada || recorrido.descripcion}</p>
    <p>{recorrido.descripcion}</p>
    <div class="chip-row">
      {recorrido.temas.map((tema) => (
        <a class="chip" href={sitePath(`/catalogo?tema=${encodeURIComponent(tema)}`)}>
          {humanize(tema)}
        </a>
      ))}
    </div>
  </section>

  <section class="section detail-grid">
    <article class="panel">
      <p class="eyebrow">Criterio editorial</p>
      <h2>Por qué existe este recorrido</h2>
      <p>{recorrido.criterio}</p>
    </article>
    <article class="panel">
      <p class="eyebrow">Territorios y escala</p>
      <h2>Mapa de lectura</h2>
      <p>{recorrido.territorios.join(" · ")}</p>
    </article>
  </section>

  <ShareBlock
    title={recorrido.titulo}
    text={`Un recorrido de Jugar Argentina para explorar: ${recorrido.temas.map(humanize).join(", ")}.`}
  />

  <section class="section recorrido-section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Curados para este recorrido</p>
        <h2>Destacados del recorrido</h2>
        <p class="section-subtitle">
          {destacados.length} juego{destacados.length === 1 ? "" : "s"} elegidos a mano, con motivo editorial explícito.
        </p>
      </div>
    </div>
    <div class="game-grid">
      {destacados.map((game) => (
        <article class="recorrido-featured">
          <GameCard game={game} fromRecorrido={recorrido.slug} />
          <p class="recorrido-featured-reason">
            {motivoForDestacado(recorrido, game.id)}
          </p>
        </article>
      ))}
    </div>
  </section>

  <section class="section panel catalog-cta">
    <h2>Explorar más en el catálogo</h2>
    <p>
      Este recorrido reúne destacados curados con criterio editorial explícito.
      En el catálogo podés ampliar la búsqueda y combinar filtros por tema, territorio o disponibilidad.
    </p>
    <a class="button button-primary" href={catalogHref}>Ver en el catálogo</a>
  </section>
</BaseLayout>
