---
import BaseLayout from "../../layouts/BaseLayout.astro";
import GameCard from "../../components/GameCard.astro";
import {
  countsForRecorrido,
  destacadosForRecorrido,
  formatRecorridoTipo,
  getTodayRecorrido,
  recorridoFechaLabel,
  recorridos,
} from "../../lib/recorridos";
import { humanize } from "../../lib/filters";
import { sitePath } from "../../lib/links";

const today = getTodayRecorrido();
const todayCounts = countsForRecorrido(today);
const todayPreview = destacadosForRecorrido(today).slice(0, 4);
const recorridosConConteo = recorridos.map((recorrido) => ({
  ...recorrido,
  conteo: countsForRecorrido(recorrido),
  fechaLabel: recorridoFechaLabel(recorrido),
  tipoLabel: formatRecorridoTipo(recorrido.tipo),
}));
---

<BaseLayout
  title="Recorridos"
  description="Recorridos editoriales por fechas patrias, territorios y ejes culturales argentinos."
>
  <section class="page-hero">
    <p class="eyebrow">Fechas patrias y recorridos</p>
    <h1>Puertas editoriales para jugar Argentina</h1>
    <p>
      Cada recorrido explica un criterio de lectura: una fecha patria, un
      territorio, un eje cultural o una forma de entrar al catálogo. Los
      juegos que ves en cada recorrido fueron elegidos y ordenados a mano.
    </p>
  </section>

  <section class="section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Hoy</p>
        <h2>{today.titulo}</h2>
        <p class="section-subtitle">{today.bajada || today.descripcion}</p>
        <p class="section-subtitle">{today.criterio}</p>
      </div>
      <a href={sitePath(`/recorridos/${today.slug}`)}>
        Ver {todayCounts.destacados} destacados curados
      </a>
    </div>
    <div class="game-grid">
      {todayPreview.map((game) => <GameCard game={game} />)}
    </div>
  </section>

  <section class="recorrido-grid">
    {
      recorridosConConteo.map((recorrido) => (
        <a class="panel recorrido-card" href={sitePath(`/recorridos/${recorrido.slug}`)}>
          <p class="recorrido-date">
            {recorrido.tipoLabel}
            {recorrido.fechaLabel ? ` · ${recorrido.fechaLabel}` : " · Todo el año"}
          </p>
          <h2>{recorrido.titulo}</h2>
          <p>{recorrido.bajada || recorrido.descripcion}</p>
          <p class="recorrido-criteria">{recorrido.criterio}</p>
          <div class="chip-row">
            {recorrido.temas.slice(0, 3).map((tema) => (
              <span class="chip">{humanize(tema)}</span>
            ))}
          </div>
          <p class="recorrido-meta">
            {recorrido.conteo.destacados} destacado{recorrido.conteo.destacados === 1 ? "" : "s"} curado{recorrido.conteo.destacados === 1 ? "" : "s"}
          </p>
        </a>
      ))
    }
  </section>
</BaseLayout>
