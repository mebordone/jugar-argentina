---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  DEFAULT_LISTA_SORT,
  LISTA_SORT_OPTIONS,
  listas,
  type ListaItem,
} from "../../lib/listas";
import { sitePath } from "../../lib/links";

export function getStaticPaths() {
  return listas.map((lista) => ({
    params: { tipo: lista.slug },
    props: { lista },
  }));
}

const { lista } = Astro.props;
const items = lista.getItems();
const showFechaAlta = lista.sortable;

function itemHref(item: ListaItem) {
  if (!item.href) return undefined;
  return item.external ? item.href : sitePath(item.href);
}
---

<BaseLayout title={lista.titulo} description={lista.descripcion}>
  <section class="page-hero">
    <a class="back-link" href={sitePath("/")}>Volver al inicio</a>
    <p class="eyebrow">Lista del catálogo</p>
    <h1>{lista.titulo}</h1>
    <p>{lista.descripcion}</p>
    <p class="lista-count">{items.length} entradas</p>
  </section>

  <section class="section">
    {
      lista.sortable ? (
        <div class="lista-sortable">
          <div class="lista-sort">
            <label for="lista-sort-select">Ordenar por</label>
            <select id="lista-sort-select" data-lista-sort>
              {LISTA_SORT_OPTIONS.map((option) => (
                <option
                  value={option.value}
                  selected={option.value === DEFAULT_LISTA_SORT}
                >
                  {option.label}
                </option>
              ))}
            </select>
          </div>
          <ol class="data-list data-list--with-date" data-lista-items>
            {items.map((item) => (
              <li
                class="data-list-item"
                data-titulo={item.titulo}
                data-fecha-alta={item.fecha_alta ?? ""}
                data-anio={item.anio ?? ""}
              >
                {item.href ? (
                  <a
                    href={itemHref(item)}
                    target={item.external ? "_blank" : undefined}
                    rel={item.external ? "noreferrer" : undefined}
                  >
                    <span class="data-list-main">
                      <span class="data-list-title">{item.titulo}</span>
                      {item.subtitulo ? (
                        <span class="data-list-meta">{item.subtitulo}</span>
                      ) : null}
                    </span>
                    {showFechaAlta && item.fecha_alta_label ? (
                      <time class="data-list-date" datetime={item.fecha_alta}>
                        <span class="data-list-date-label">Alta</span>
                        {item.fecha_alta_label}
                      </time>
                    ) : null}
                  </a>
                ) : (
                  <div>
                    <span class="data-list-main">
                      <span class="data-list-title">{item.titulo}</span>
                      {item.subtitulo ? (
                        <span class="data-list-meta">{item.subtitulo}</span>
                      ) : null}
                    </span>
                    {showFechaAlta && item.fecha_alta_label ? (
                      <time class="data-list-date" datetime={item.fecha_alta}>
                        <span class="data-list-date-label">Alta</span>
                        {item.fecha_alta_label}
                      </time>
                    ) : null}
                  </div>
                )}
              </li>
            ))}
          </ol>
        </div>
      ) : (
        <ol class="data-list">
          {items.map((item) => (
            <li class="data-list-item">
              {item.href ? (
                <a
                  href={itemHref(item)}
                  target={item.external ? "_blank" : undefined}
                  rel={item.external ? "noreferrer" : undefined}
                >
                  <span class="data-list-title">{item.titulo}</span>
                  {item.subtitulo ? (
                    <span class="data-list-meta">{item.subtitulo}</span>
                  ) : null}
                </a>
              ) : (
                <div>
                  <span class="data-list-title">{item.titulo}</span>
                  {item.subtitulo ? (
                    <span class="data-list-meta">{item.subtitulo}</span>
                  ) : null}
                </div>
              )}
            </li>
          ))}
        </ol>
      )
    }
  </section>
</BaseLayout>

{
  lista.sortable ? (
    <script>
      import {
        sortListaItems,
        type ListaSortKey,
      } from "../../lib/listaSort";

      function bindListaSort() {
        const select = document.querySelector<HTMLSelectElement>("[data-lista-sort]");
        const list = document.querySelector<HTMLOListElement>("[data-lista-items]");
        if (!select || !list) return;

        const applySort = () => {
          const sortKey = select.value as ListaSortKey;
          const rows = Array.from(list.querySelectorAll<HTMLLIElement>(":scope > li"));
          const sorted = sortListaItems(
            rows.map((row) => ({
              row,
              titulo: row.dataset.titulo ?? "",
              fecha_alta: row.dataset.fechaAlta || undefined,
              anio: row.dataset.anio ? Number(row.dataset.anio) : null,
            })),
            sortKey,
          );
          for (const item of sorted) {
            list.appendChild(item.row);
          }
        };

        select.addEventListener("change", applySort);
      }

      bindListaSort();
    </script>
  ) : null
}
