{
  "name": "jugar-argentina",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "npm run data:publish && astro check && astro build && npm run search:index",
    "preview": "astro preview",
    "validate:data": "python3 scripts/validate.py",
    "validate:links": "python3 scripts/validate_links.py",
    "validate:external": "python3 scripts/validate_external_links.py",
    "validate": "npm run validate:data && npm run validate:links",
    "test:filters": "npx tsx scripts/test_filters.ts",
    "data:report": "python3 scripts/report_quality.py",
    "data:years": "python3 scripts/harvest_years.py --apply",
    "data:years:apply-pending": "python3 scripts/apply_year_candidates.py",
    "data:years:manual": "python3 scripts/apply_year_manual.py",
    "steam:search": "python3 scripts/steam_search.py",
    "steam:triage": "python3 scripts/triage_steam_candidates.py",
    "harvest:covers": "python3 scripts/harvest_covers.py",
    "data:covers": "python3 scripts/harvest_covers.py --apply",
    "data:covers:manual": "python3 scripts/apply_cover_manual.py",
    "data:patch-links": "python3 scripts/apply_play_links.py",
    "data:infer": "python3 scripts/infer_disponibilidad.py",
    "data:ejes": "python3 scripts/propagate_ejes.py",
    "data:grados": "python3 scripts/reclassify_grados.py",
    "data:sync-csv": "python3 scripts/sync_csv_triage.py",
    "data:build": "python3 scripts/apply_play_links.py && python3 scripts/infer_disponibilidad.py && python3 scripts/propagate_ejes.py && python3 scripts/reclassify_grados.py && python3 scripts/harvest_covers.py && python3 scripts/harvest_captures.py && python3 scripts/sync_csv_triage.py",
    "harvest:captures": "python3 scripts/harvest_captures.py",
    "data:publish": "mkdir -p public/data && cp data/games.json public/data/games.json",
    "search:index": "npx pagefind --site dist --output-path dist/pagefind || true"
  },
  "dependencies": {
    "@astrojs/check": "latest",
    "@astrojs/react": "latest",
    "@astrojs/sitemap": "^3.7.3",
    "astro": "latest",
    "react": "latest",
    "react-dom": "latest",
    "typescript": "latest"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "pagefind": "^1.5.2"
  }
}
